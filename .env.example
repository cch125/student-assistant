RAGFLOW_BASE_URL=http://host.docker.internal:8080
RAGFLOW_API_KEY=replace-with-a-new-ragflow-api-token
ASSISTANT_HOST=0.0.0.0
ASSISTANT_PORT=8090
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60
MAX_QUESTION_LENGTH=300
MAX_BODY_BYTES=31457280
MAX_UPLOAD_FILE_BYTES=12582912
MAX_UPLOAD_FILES=10
# 本机开发连接 localhost/内网 RAGFlow 时设为 1；公网部署保持 0。
ALLOW_PRIVATE_RAGFLOW=1

# Vercel 照片提问使用的 OpenAI 兼容视觉模型（只在 Vercel 环境变量中填写真实密钥）
VLM_BASE_URL=https://api.siliconflow.cn/v1
VLM_API_KEY=replace-with-a-new-vision-api-key
VLM_MODEL=Qwen/Qwen2.5-VL-72B-Instruct

# 重型多智能体链路使用的 OpenAI 兼容文本模型。
# 不配置时系统会自动回退规则 Router / 原文回答 / 规则质检，演示不会中断。
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_API_KEY=replace-with-a-new-llm-api-key
LLM_MODEL=Qwen/Qwen2.5-32B-Instruct
